# Use one of these templates instead:
#
# Local development:
#   cp .env.local.example .env.local
#   npm run dev:local
#
# Production-style local run:
#   cp .env.production.example .env.production
#   npm run build
#   npm run start:production
#
# Render deployment:
#   Copy the keys from .env.production.example into Render Dashboard > Environment.
