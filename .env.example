PORT=3001
HOST="127.0.0.1"
APP_BASE_URL="http://localhost:3001"
SESSION_SECRET="local-development-secret-change-before-production"

# Local demo lets the student page run without LINE/Google credentials.
LOCAL_DEMO_ENABLED=true
MOCK_SHEET_ENABLED=true

# LINE Login channel used by LIFF. Fill these when connecting real LIFF.
LINE_LOGIN_CHANNEL_ID="your-line-login-channel-id"
LIFF_ID="your-liff-id"

# Google Sheets
GOOGLE_SPREADSHEET_ID="your-google-spreadsheet-id"
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
